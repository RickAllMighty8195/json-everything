@using JsonEverythingNet.Models

<div id="@_fieldId" class="bubble-field">
	@foreach (var item in Data)
	{
		<SponsorBubble AvatarUrl="@item.AvatarUrl?.OriginalString"
		               WebsiteUrl="@item.WebsiteUrl?.OriginalString"
		               Username="@item.Username"
		               Size="@item.BubbleSize"
		               X="@item.X"
		               Y="@item.Y">
		</SponsorBubble>
	}
</div>

@code {
	[Inject]
	private IJSRuntime JsRuntime { get; set; } = default!;

	private readonly string _fieldId = $"sponsor-cloud-{Guid.NewGuid():N}";

	[Parameter]
	public IReadOnlyList<SponsorData> Data { get; set; } = [];

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (Data.Count == 0) return;

		await JsRuntime.InvokeVoidAsync("sponsorCloudLayout.layout", _fieldId);

		await base.OnAfterRenderAsync(firstRender);
	}

}
